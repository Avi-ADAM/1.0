{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "1lev1",
  "version": "0.1.0",
  "identifier": "world.1lev1.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:mobile",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "1lev1",
        "width": 1100,
        "height": 750
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
